<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: dumbbell in solid white.
  108dp canvas; artwork stays inside the 72dp safe zone (18dp inset each side).
  The dumbbell is drawn at ~18-degree tilt to match the icon design.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      All coordinates are for a 108×108 viewport.
      Safe zone: 18dp inset → artwork between x=18..90, y=18..90.
      Dumbbell tilted ~-18° around center (54,54).

      Pieces (in un-rotated space, then rotated -18° around 54,54):
        Bar:        x=27..81  y=51.7..56.3  (length 54, height 4.6)
        L-collar:   x=23..29  y=48..60      (width 6,  height 12)
        R-collar:   x=79..85  y=48..60
        L-plate:    x=16..23  y=42..66      (width 7,  height 24)
        R-plate:    x=85..92  y=42..66
        L-endcap:   x=12..16  y=45..63      (width 4,  height 18)
        R-endcap:   x=92..96  y=45..63

      Encoded as a single compound path using rotate() transform.
    -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:rotation="-18">

        <!-- Bar -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M28,51.7 L80,51.7 Q81,51.7 81,52.7 L81,55.3 Q81,56.3 80,56.3 L28,56.3 Q27,56.3 27,55.3 L27,52.7 Q27,51.7 28,51.7 Z" />

        <!-- Left inner collar -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M23,48 L29,48 Q30,48 30,49 L30,59 Q30,60 29,60 L23,60 Q22,60 22,59 L22,49 Q22,48 23,48 Z" />

        <!-- Right inner collar -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M78,48 L84,48 Q85,48 85,49 L85,59 Q85,60 84,60 L78,60 Q77,60 77,59 L77,49 Q77,48 78,48 Z" />

        <!-- Left outer plate -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M16,42 L23,42 Q24,42 24,43 L24,65 Q24,66 23,66 L16,66 Q15,66 15,65 L15,43 Q15,42 16,42 Z" />

        <!-- Right outer plate -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M85,42 L92,42 Q93,42 93,43 L93,65 Q93,66 92,66 L85,66 Q84,66 84,65 L84,43 Q84,42 85,42 Z" />

        <!-- Left end cap -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M12,45 L16,45 Q17,45 17,46 L17,62 Q17,63 16,63 L12,63 Q11,63 11,62 L11,46 Q11,45 12,45 Z" />

        <!-- Right end cap -->
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M92,45 L96,45 Q97,45 97,46 L97,62 Q97,63 96,63 L92,63 Q91,63 91,62 L91,46 Q91,45 92,45 Z" />

    </group>

</vector>
